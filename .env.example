# Master key for encrypting stored API keys. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional: default display refresh interval (seconds)
DEFAULT_REFRESH_SECONDS=60

# Optional: stock data cache TTL (seconds)
STOCK_CACHE_TTL=60
